@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Roles";
}

<h1>Roles Management</h1>

<form asp-action="Create" method="post" class="mb-3">
    <div class="form-group">
        <label for="roleName">New Role</label>
        <input type="text" id="roleName" name="roleName" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary mt-2">Create Role</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Role Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.Name</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>