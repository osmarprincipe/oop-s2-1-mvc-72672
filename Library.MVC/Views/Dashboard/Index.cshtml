@model Library.MVC.Models.DashboardViewModel
@using Library.Domain.Enums

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<form method="get" asp-action="Index" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label for="town" class="form-label">Town</label>
            <select name="town" id="town" class="form-control">
                <option value="">All Towns</option>
                @foreach (var town in Model.Towns)
                {
                    if (Model.SelectedTown == town)
                    {
                        <option value="@town" selected>@town</option>
                    }
                    else
                    {
                        <option value="@town">@town</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-4">
            <label for="riskRating" class="form-label">Risk Rating</label>
            <select name="riskRating" class="form-control">
                <option value="">All Risk Ratings</option>

                @foreach (var item in Html.GetEnumSelectList<RiskRating>())
                {
                    if (Model.SelectedRiskRating != null && item.Value == ((int)Model.SelectedRiskRating).ToString())
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-4 mt-4">
            <button type="submit" class="btn btn-primary">Apply Filters</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card p-3">
            <h4>Inspections This Month</h4>
            <p>@Model.InspectionsThisMonth</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <h4>Failed Inspections This Month</h4>
            <p>@Model.FailedInspectionsThisMonth</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <h4>Overdue Open Follow-Ups</h4>
            <p>@Model.OverdueOpenFollowUps</p>
        </div>
    </div>
</div>

<h3>Filtered Premises</h3>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Town</th>
            <th>Risk Rating</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PremisesResults)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Town</td>
                <td>@item.RiskRating</td>
            </tr>
        }
    </tbody>
</table>